# Build stage
FROM rust:{{ .RustVersion }}-alpine AS builder

RUN apk add --no-cache musl-dev ca-certificates

WORKDIR /app

COPY code/ ./code/
WORKDIR /app/code
RUN cargo build --release

# Final stage
FROM alpine:{{ .AlpineVersion }}

RUN apk add --no-cache ca-certificates

WORKDIR /app

{{ range .Envs }}
ENV {{ .Key }}={{ .Value }}
{{ end }}

RUN adduser -D appuser
# The factory Cargo.toml pins the binary name to `app`.
COPY --chown=appuser --from=builder /app/code/target/release/app .
USER appuser

EXPOSE 8080
CMD ["./app"]
